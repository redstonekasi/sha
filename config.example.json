{
	"release": {
		"port": 9080,
		"host": "https://inject.shelter.uwu.network"
	},
	"staging": {
		"supervisor": {
			"branch": "main"
		},
		"port": 9081,
		"host": "https://staging.shelter.uwu.network"
	},
	"_": {
		"supervisor": {
			"repository": "https://github.com/uwu/sheltupdate",
			"key": "meow"
		},
		"stats": true,
		"setupIntervalHours": 3,
		"proxy": {
			"cache": {
				"lastUsedRemoveHours": 1,
				"maxMinutesToUseCached": 30
			},
			"useragent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) discord/0.0.76 Chrome/128.0.6613.186 Electron/32.2.2 Safari/537.36"
		},
		"apiBases": {
			"v1": "https://discord.com/api",
			"v2": "https://discord.com/api/updates"
		}
	}
}
